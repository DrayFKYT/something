local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- State Management
local KeenToggled, ScentToggled, AggressionToggled, CowerToggled = false, false, false, false
local InfiniteStaminaToggled, InfiniteOxygenToggled, InfiniteMoistureToggled = false, false, false
local WalkEnabled, SprintEnabled, FlyEnabled, SwimEnabled = false, false, false, false
local WalkSpeedValue, SprintSpeedValue, FlySpeedValue, SwimSpeedValue = 16, 16, 16, 16

local GuiVisible = true
local KeenInitialized = false
local HideGuiKey = Enum.KeyCode.P

-- Remotes
local Remotes = ReplicatedStorage:WaitForChild("Remotes", 10)
local StateAilmentRemote = Remotes and Remotes:FindFirstChild("StateAilment")
local HideScentRemote = Remotes and Remotes:FindFirstChild("HideScent")

----------------------------------------------------------------
-- HEARTBEAT LOOP (Forces Attributes)
----------------------------------------------------------------

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local data = char and char:FindFirstChild("Data")
    if not data then return end
    
    if InfiniteStaminaToggled then
        data:SetAttribute("st", 99999999999999)
        data:SetAttribute("sr", 99999999999999)
    end
    if InfiniteOxygenToggled then data:SetAttribute("Oxygen", 99999999999999) end
    if InfiniteMoistureToggled then data:SetAttribute("Moisture", 99999999999999) end
    
    if WalkEnabled then data:SetAttribute("s", WalkSpeedValue) end
    if SwimEnabled then data:SetAttribute("s", SwimSpeedValue) end 
    if SprintEnabled then data:SetAttribute("ss", SprintSpeedValue) end
    if FlyEnabled then data:SetAttribute("fs", FlySpeedValue) end

    if ScentToggled then
        char:SetAttribute("ScentHidden", true)
        if HideScentRemote then HideScentRemote:FireServer(true) end
    end
    if AggressionToggled and StateAilmentRemote then StateAilmentRemote:FireServer("Aggression") end
    if CowerToggled and StateAilmentRemote then StateAilmentRemote:FireServer("Cower") end
end)

----------------------------------------------------------------
-- KEEN OBSERVER (ESP) LOGIC
----------------------------------------------------------------
local ActiveGuis = {}

local function GetModule(name)
    local found = ReplicatedStorage:FindFirstChild(name, true)
    if found and found:IsA("ModuleScript") then return require(found) end
    return nil
end

local GuiUtils = GetModule("GuiUtils")
local WorldspaceGuiUtils = GetModule("WorldspaceGuiUtils")
local OverheadHealthbar = GetModule("OverheadHealthbar")
local UI_Template = ReplicatedStorage:FindFirstChild("OverheadGui", true) 

local function CreateKeenUI(TargetCharacter)
    if not TargetCharacter or TargetCharacter == LocalPlayer.Character or ActiveGuis[TargetCharacter] then return end 
    local PlayerObj = Players:GetPlayerFromCharacter(TargetCharacter)
    if not PlayerObj or not UI_Template then return end

    local NewGui = UI_Template:Clone()
    NewGui.Name = PlayerObj.Name .. "_ForceObserver"
    NewGui.Enabled = KeenToggled 
    NewGui.Adornee = TargetCharacter
    
    if GuiUtils then GuiUtils.ParentToWorkspaceGui(NewGui) end
    if WorldspaceGuiUtils then WorldspaceGuiUtils.AddWorldspaceGui(NewGui) end
    if OverheadHealthbar then
        OverheadHealthbar.new(PlayerObj, NewGui:WaitForChild("Health"))
        ActiveGuis[TargetCharacter] = NewGui 
    end
end

local function ToggleKeen(state)
    KeenToggled = state
    if state and not KeenInitialized then
        KeenInitialized = true
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character then task.spawn(CreateKeenUI, p.Character) end
            p.CharacterAdded:Connect(function(char) task.spawn(CreateKeenUI, char) end)
        end
        Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function(char) task.spawn(CreateKeenUI, char) end) end)
    end
    for char, gui in pairs(ActiveGuis) do if gui then gui.Enabled = state end end
end

