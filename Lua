RunService.Heartbeat:Connect(function()
    if not (Toggles.AutoSkill or Toggles.Autofarm) or skillCheckActive then return end

    local circleGui = PlayerGui:FindFirstChild("CircleSkillCheckGui")
    if circleGui then
        local yellow = circleGui:FindFirstChild("YellowCircle", true)
        local shrinking = circleGui:FindFirstChild("ShrinkingCircle", true)
        if yellow and shrinking and shrinking.Visible then
            local diff = shrinking.AbsoluteSize.X - yellow.AbsoluteSize.X
            if diff <= 7 and diff >= -2 then
                skillCheckActive = true
                press()
                task.spawn(function()
                    repeat task.wait() until not PlayerGui:FindFirstChild("CircleSkillCheckGui") or shrinking.AbsoluteSize.X > yellow.AbsoluteSize.X + 20
                    task.wait(0.1)
                    skillCheckActive = false
                end)
            end
        end
    end

    local needleUi = PlayerGui:FindFirstChild("SkillCheckFrame", true)
    if needleUi and needleUi.Visible then
        local marker = needleUi:FindFirstChild("Marker")
        local gold = needleUi:FindFirstChild("GoldArea")
        if marker and gold then
            local mPos = marker.AbsolutePosition + (marker.AbsoluteSize / 2)
            local objects = PlayerGui:GetGuiObjectsAtPosition(mPos.X, mPos.Y)
            for _, obj in pairs(objects) do
                if obj == gold then
                    skillCheckActive = true
                    press()
                    task.spawn(function()
                        repeat task.wait() until not needleUi.Visible
                        skillCheckActive = false
                    end)
                end
            end
        end
    end
end)

local function handleTreadmill(gui)
    if not (Toggles.AutoSkill or Toggles.Autofarm) then return end
    local container = gui:WaitForChild("TapSkillCheckFrame", 5):WaitForChild("Container", 5)
    local tapButton = container:WaitForChild("TapButton", 5)
    if tapButton then
        while gui and gui.Parent and (Toggles.AutoSkill or Toggles.Autofarm) do
            press()
            task.wait(0.02)
            local counter = container:FindFirstChild("TapCounter")
            if counter and counter.Text == "SUCCESS!" then break end
        end
    end
end

PlayerGui.ChildAdded:Connect(function(child)
    if child.Name == "TreadmillTapSkillCheckGui" then handleTreadmill(child) end
end)

