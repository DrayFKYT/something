local function SendMonsterChat()
    local monsterList = {}
    local room = workspace:FindFirstChild("CurrentRoom")
    if room then
        for _, part in pairs(room:GetChildren()) do
            if part:FindFirstChild("Monsters") then
                for _, m in pairs(part.Monsters:GetChildren()) do table.insert(monsterList, m.Name) end
            end
        end
    end
    if #monsterList > 0 then
        local msg = "Monsters: " .. table.concat(monsterList, ", ")
        if TextChatService.TextChannels:FindFirstChild("RBXGeneral") then
            TextChatService.TextChannels.RBXGeneral:SendAsync(msg)
        else
            local chatEvent = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
            if chatEvent then chatEvent:FireServer(msg, "All") end
        end
    end
end

local function TeleportTo(obj)
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") and obj then
        local target = obj:FindFirstChild("ScrapsAttachPoint", true) or (obj:IsA("Model") and obj.PrimaryPart) or obj
        char.HumanoidRootPart.CFrame = (target:IsA("Attachment") and target.WorldCFrame or target.CFrame) + Vector3.new(0, 3, 0)
        task.wait(0.05)
        KillVelocity()
    end
end

local function CreateESP(obj, color, toggle)
    if not obj or not obj.Parent then return end
    if color == Color3.fromRGB(0, 120, 255) then
        if not Players:GetPlayerFromCharacter(obj) then return end
    end
    local id = obj:GetDebugId()
    local existing = ESPFolder:FindFirstChild(id)
    if toggle then
        if not existing then
            local hl = Instance.new("Highlight")
            hl.Name = id; hl.Adornee = obj; hl.FillColor = color; hl.FillTransparency = 0.7; hl.OutlineTransparency = 0; hl.Parent = ESPFolder
        end
    else
        if existing then existing:Destroy() end
    end
end

