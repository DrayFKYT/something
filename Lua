local buttonY = 70 
local function CreateSwitch(name, toggleKey)
    local Btn = Instance.new("TextButton", MainFrame)
    Btn.BackgroundColor3 = Toggles[toggleKey] and Color3.fromRGB(0, 80, 220) or Color3.fromRGB(35, 35, 45)
    Btn.Font = Enum.Font.GothamMedium
    Btn.TextColor3 = Toggles[toggleKey] and Color3.new(1, 1, 1) or Color3.fromRGB(180, 180, 180)
    Btn.TextSize = 12
    Btn.Text = name .. (Toggles[toggleKey] and ": ON" or ": OFF")
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 10)

    if toggleKey == "MonsterESP" then
        Btn.Size = UDim2.new(0, 155, 0, 40); Btn.Position = UDim2.new(0, 25, 0, buttonY)
        local ChatBtn = Instance.new("TextButton", MainFrame)
        ChatBtn.Size = UDim2.new(0, 40, 0, 40); ChatBtn.Position = UDim2.new(0, 185, 0, buttonY); ChatBtn.BackgroundColor3 = Color3.fromRGB(0, 80, 220); ChatBtn.Text = "💬"; ChatBtn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", ChatBtn).CornerRadius = UDim.new(0, 8); ChatBtn.MouseButton1Click:Connect(SendMonsterChat)
        
        local AutoCheck = Instance.new("TextButton", MainFrame)
        AutoCheck.Size = UDim2.new(0, 200, 0, 25); AutoCheck.Position = UDim2.new(0, 25, 0, buttonY + 45); AutoCheck.BackgroundColor3 = Toggles.AutoChat and Color3.fromRGB(0, 80, 220) or Color3.fromRGB(28, 28, 38)
        AutoCheck.Text = "Auto-Chat Monsters: " .. (Toggles.AutoChat and "ON" or "OFF")
        AutoCheck.TextColor3 = Toggles.AutoChat and Color3.new(1,1,1) or Color3.fromRGB(150, 150, 150)
        AutoCheck.TextSize = 12; AutoCheck.Font = Enum.Font.GothamMedium
        Instance.new("UICorner", AutoCheck).CornerRadius = UDim.new(0, 6)
        
        AutoCheck.MouseButton1Click:Connect(function() 
            Toggles.AutoChat = not Toggles.AutoChat
            AutoCheck.BackgroundColor3 = Toggles.AutoChat and Color3.fromRGB(0, 80, 220) or Color3.fromRGB(28, 28, 38)
            AutoCheck.Text = "Auto-Chat Monsters: " .. (Toggles.AutoChat and "ON" or "OFF")
            AutoCheck.TextColor3 = Toggles.AutoChat and Color3.new(1,1,1) or Color3.fromRGB(150, 150, 150) 
            SaveConfig()
        end)
        buttonY = buttonY + 80
    else
        Btn.Size = UDim2.new(0, 200, 0, 40); Btn.Position = UDim2.new(0, 25, 0, buttonY)
        buttonY = buttonY + 50
    end

    Btn.MouseButton1Click:Connect(function()
        Toggles[toggleKey] = not Toggles[toggleKey]
        Btn.BackgroundColor3 = Toggles[toggleKey] and Color3.fromRGB(0, 80, 220) or Color3.fromRGB(35, 35, 45)
        Btn.Text = name .. (Toggles[toggleKey] and ": ON" or ": OFF")
        Btn.TextColor3 = Toggles[toggleKey] and Color3.new(1, 1, 1) or Color3.fromRGB(180, 180, 180)
        if toggleKey == "ShowList" then ListFrame.Visible = Toggles.ShowList end
        if toggleKey ~= "Autofarm" then SaveConfig() end
    end)
end

