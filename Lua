local lockedGen = nil
local isInteracting = false
local safetyLock = false
local levelReady = false 
local CAMP_CHECK_DISTANCE = 70 

-- Variables for Sprout Staged Teleport
local sproutTeleportTimer = 0
local teleportStage = 0 -- 0: None, 1: Second Safest, 2: Safest

local function getRoomFolder(name)
    local room = workspace:FindFirstChild("CurrentRoom")
    if not room then return nil end
    for _, child in pairs(room:GetChildren()) do
        local f = child:FindFirstChild(name, true)
        if f then return f end
    end
    return nil
end

-- Selection Guard: Treats tendrils, blot hands, and monsters as hazards
local function isAreaSafe(targetPosition)
    local monsters = getRoomFolder("Monsters")
    local room = workspace:FindFirstChild("CurrentRoom")
    
    if monsters then
        for _, m in pairs(monsters:GetChildren()) do
            if m.Name ~= "RazzleDazzleMonster" and m.Name ~= "RodgerMonster" and m.Name ~= "BlottMonster" then
                local mPart = m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart")
                if mPart and (mPart.Position - targetPosition).Magnitude < CAMP_CHECK_DISTANCE then
                    return false
                end
            end
        end
    end

    -- Avoid environmental hazards during selection
    if room then
        for _, desc in pairs(room:GetDescendants()) do
            -- Treat BlotHandZone names as hazards
            if (desc.Name == "SproutTendril" or desc.Name:find("BlotHandZone")) and desc:IsA("BasePart") then
                if (desc.Position - targetPosition).Magnitude < 40 then
                    return false
                end
            end
        end
    end

    return true
end

-- Reaction Layer: STAGED TELEPORT FOR SPROUTMONSTER + HAZARD DETECTION
RunService.Heartbeat:Connect(function()
    if not Toggles.Autofarm then return end
    local monsters = getRoomFolder("Monsters")
    local gens = getRoomFolder("Generators")
    local room = workspace:FindFirstChild("CurrentRoom")
    if not monsters or not gens or not room then return end

    local dangerDetected = false
    local isSproutChasing = false

    -- Check for Monster Chase
    for _, m in pairs(monsters:GetChildren()) do
        if m.Name ~= "RazzleDazzleMonster" and m.Name ~= "RodgerMonster" and m.Name ~= "BlottMonster" then
            local chase = m:FindFirstChild("ChasingValue")
            if chase and chase.Value and (chase.Value == LocalPlayer or tostring(chase.Value):lower() == LocalPlayer.Name:lower()) then
                dangerDetected = true
                if m.Name == "SproutMonster" then
                    isSproutChasing = true
                end
                break
            end
        end
    end

    -- Trigger emergency if Hazards (Tendril or Blot Hands) are close, even if not chased
    if not dangerDetected then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local playerPos = char.HumanoidRootPart.Position
            for _, desc in pairs(room:GetDescendants()) do
                if (desc.Name == "SproutTendril" or desc.Name:find("BlotHandZone")) and desc:IsA("BasePart") then
                    if (desc.Position - playerPos).Magnitude < 30 then 
                        dangerDetected = true; break
                    end
                end
            end
        end
    end

    if dangerDetected then
        safetyLock = true
        isInteracting = false 
        lockedGen = nil
        
        local safetyList = {}
        
        -- Score all generators by distance from threats
        for _, g in pairs(gens:GetChildren()) do
            local p = g:FindFirstChild("ScrapsAttachPoint", true)
            if p then
                local minDistanceToAnyThreat = 9999
                
                -- Monster proximity
                for _, m in pairs(monsters:GetChildren()) do
                    if m.PrimaryPart then
                        local d = (p.Position - m.PrimaryPart.Position).Magnitude
                        if d < minDistanceToAnyThreat then minDistanceToAnyThreat = d end
                    end
                end
                
                -- Environmental Hazard proximity
                for _, desc in pairs(room:GetDescendants()) do
                    if (desc.Name == "SproutTendril" or desc.Name:find("BlotHandZone")) and desc:IsA("BasePart") then
                        local d = (p.Position - desc.Position).Magnitude
                        if d < minDistanceToAnyThreat then minDistanceToAnyThreat = d end
                    end
                end

                table.insert(safetyList, {Part = p, Dist = minDistanceToAnyThreat, Model = g})
            end
        end
        
        -- Sort: Index 1 is safest (furthest), Index 2 is second safest
        table.sort(safetyList, function(a, b) return a.Dist > b.Dist end)

        if #safetyList > 0 then
            local targetData = nil
            
            if isSproutChasing then
                if teleportStage == 0 then
                    -- Stage 1: Move to 2nd safest immediately
                    targetData = safetyList[2] or safetyList[1]
                    teleportStage = 1
                    sproutTeleportTimer = tick()
                elseif teleportStage == 1 then
                    -- Check if 1 second has passed to move to safest
                    if tick() - sproutTeleportTimer >= 1 then
                        targetData = safetyList[1]
                        teleportStage = 2
                    else
                        targetData = safetyList[2] or safetyList[1]
                    end
                else
                    -- Already at safest
                    targetData = safetyList[1]
                end
            else
                -- Normal danger/Hazard: Go straight to safest
                targetData = safetyList[1]
                teleportStage = 0
            end

            -- Execute Teleport
            if targetData then 
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local p = targetData.Part
                    local g = targetData.Model
                    
                    local targetPos = p.Position
                    local modelHeight = g:GetExtentsSize().Y
                    local modelCenterY = g:GetPivot().Y
                    local roofY = modelCenterY + (modelHeight / 2) + 85
                    
                    char.HumanoidRootPart.CFrame = CFrame.new(targetPos.X, roofY, targetPos.Z)
                    KillVelocity()
                    
                    -- Force Close Generator UI
                    local stopButton = PlayerGui:FindFirstChild("ScreenGui") 
                        and PlayerGui.ScreenGui:FindFirstChild("Menu") 
                        and PlayerGui.ScreenGui.Menu:FindFirstChild("StopGenerator")
                    if stopButton and stopButton.Visible then
                        local absPos = stopButton.AbsolutePosition
                        local absSize = stopButton.AbsoluteSize
                        VIM:SendMouseButtonEvent(absPos.X + (absSize.X/2), absPos.Y + (absSize.Y/2), 0, true, game, 1)
                        VIM:SendMouseButtonEvent(absPos.X + (absSize.X/2), absPos.Y + (absSize.Y/2), 0, false, game, 1)
                    end
                end
            end
        end
    else
        safetyLock = false
        teleportStage = 0 -- Reset when danger is gone
    end
end)

task.spawn(function()
    while true do
        task.wait(0.5)
        if not Toggles.Autofarm then continue end

        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
        local root = char.HumanoidRootPart
        local currentRoom = workspace:FindFirstChild("CurrentRoom")
        local gens = getRoomFolder("Generators")
        local items = getRoomFolder("Items")
        
        if not currentRoom or not gens or #gens:GetChildren() == 0 then
            levelReady = false; isInteracting = false; lockedGen = nil
            continue 
        end

        if not levelReady then task.wait(5); levelReady = true end
        if safetyLock then continue end

        local incompleteGensFound = false
        if gens then
            if lockedGen then
                local stats = lockedGen:FindFirstChild("Stats", true)
                local comp = stats and stats:FindFirstChild("Completed")
                if not comp or comp.Value == true then lockedGen = nil; isInteracting = false end
            end
            for _, g in pairs(gens:GetChildren()) do
                local stats = g:FindFirstChild("Stats", true)
                local comp = stats and stats:FindFirstChild("Completed")
                if comp and comp.Value == false then
                    incompleteGensFound = true
                    local attach = g:FindFirstChild("ScrapsAttachPoint", true)
                    if attach and isAreaSafe(attach.Position) then
                        local connie = stats:FindFirstChild("Connie")
                        if not (connie and connie.Value == true) and not lockedGen then
                            lockedGen = g; break
                        end
                    end
                end
            end
        end

        if lockedGen and not safetyLock then
            local p = lockedGen:FindFirstChild("ScrapsAttachPoint", true)
            if p then
                if (root.Position - p.Position).Magnitude > 5 then
                    root.CFrame = p.CFrame
                    KillVelocity()
                    isInteracting = false 
                    task.wait(0.3)
                end
                while lockedGen and not safetyLock and not isInteracting do
                    local prompt = lockedGen:FindFirstChild("ProximityPrompt", true)
                    if prompt and prompt.Enabled then
                        isInteracting = true
                        fireproximityprompt(prompt)
                        break 
                    else
                        root.CFrame = root.CFrame * CFrame.new(0, 0, 0.05)
                        task.wait(0.1)
                        root.CFrame = root.CFrame * CFrame.new(0, 0, -0.05)
                        KillVelocity()
                    end
                    task.wait(0.1)
                end
            end
            continue 
        end

        local capsulesFound = false
        if not incompleteGensFound and items then
            local capsuleList = {}
            for _, item in pairs(items:GetChildren()) do
                if item.Name == "ResearchCapsule" then
                    local capPos = item:IsA("Model") and item:GetPivot().Position or item.Position
                    if isAreaSafe(capPos) then table.insert(capsuleList, item) end
                end
            end
            if #capsuleList > 0 then
                capsulesFound = true
                local target = capsuleList[1]
                if not safetyLock then
                    local pos = target:IsA("Model") and target:GetPivot().Position or target.Position
                    if (root.Position - pos).Magnitude > 5 then
                        root.CFrame = CFrame.new(pos)
                        KillVelocity()
                        task.wait(0.3)
                    end
                    local capsuleGrabbed = false
                    while target.Parent ~= nil and not safetyLock and not capsuleGrabbed do
                        local capPrompt = target:FindFirstChild("ProximityPrompt", true)
                        if capPrompt and capPrompt.Enabled then
                            fireproximityprompt(capPrompt); capsuleGrabbed = true; task.wait(0.2)
                        else
                            root.CFrame = root.CFrame * CFrame.new(0, 0, 0.05); task.wait(0.1)
                            root.CFrame = root.CFrame * CFrame.new(0, 0, -0.05)
                            KillVelocity()
                        end
                        task.wait(0.1)
                    end
                end
                continue 
            end
        end

        if not incompleteGensFound and not capsulesFound and not safetyLock then
            local elevatorPart = workspace:FindFirstChild("Elevators") and workspace.Elevators:FindFirstChild("Elevator")
            if elevatorPart then
                local targetCFrame = elevatorPart:IsA("Model") and elevatorPart:GetPivot() or elevatorPart.CFrame
                if (root.Position - targetCFrame.Position).Magnitude > 3 then
                    root.CFrame = targetCFrame * CFrame.new(0, 3.5, 0)
                    KillVelocity()
                    task.wait(2)
                end
            end
        end
    end
end)

