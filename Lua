                if part:IsA("Model") or part:IsA("Folder") then
                    if part:FindFirstChild("Monsters") then
                        for _, m in pairs(part.Monsters:GetChildren()) do CreateESP(m, Color3.fromRGB(255, 50, 50), Toggles.MonsterESP) end
                    end
                    if part:FindFirstChild("Generators") then
                        for _, g in pairs(part.Generators:GetChildren()) do
                            local isDone = g:FindFirstChild("Stats") and g.Stats:FindFirstChild("Completed") and g.Stats.Completed.Value == true
                            CreateESP(g, Color3.fromRGB(0, 255, 180), Toggles.GenESP and not isDone)
                        end
                    end
                    if part:FindFirstChild("Items") then
                        for _, i in pairs(part.Items:GetChildren()) do
                            if i.Name == "ResearchCapsule" then CreateESP(i, Color3.fromRGB(255, 200, 0), Toggles.CapsuleESP)
                            elseif i.Name == "HealthKit" or i.Name == "Bandage" then CreateESP(i, Color3.fromRGB(0, 255, 100), Toggles.HealthESP) end
                        end
                    end
                end
            end
            
            for _, desc in pairs(room:GetDescendants()) do
                if (desc.Name == "SproutTendril" or desc.Name:find("BlotHandZone")) and desc:IsA("BasePart") then
                    CreateESP(desc, Color3.fromRGB(255, 80, 0), Toggles.MonsterESP)
                end
            end
        else
            for _, hl in pairs(ESPFolder:GetChildren()) do
                local target = hl.Adornee
                if target and not Players:GetPlayerFromCharacter(target) then hl:Destroy() end
            end
        end

        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then CreateESP(p.Character, Color3.fromRGB(0, 120, 255), Toggles.PlayerESP) end
        end
        
        if Toggles.ShowList then
            if room and #room:GetChildren() > 0 then
                for _, child in pairs(ScrollingFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
                local entries = {}
                for _, part in pairs(room:GetChildren()) do
                    if part:IsA("Model") or part:IsA("Folder") then
                        if Toggles.TrackMonsters and part:FindFirstChild("Monsters") then
                            for _, m in pairs(part.Monsters:GetChildren()) do table.insert(entries, {Name = "[M] "..m.Name, Obj = m, Color = Color3.fromRGB(255, 50, 50), Order = 1, CanTP = false}) end
                        end
                        if Toggles.TrackGens and part:FindFirstChild("Generators") then
                            for _, g in pairs(part.Generators:GetChildren()) do 
                                local isDone = g:FindFirstChild("Stats") and g.Stats:FindFirstChild("Completed") and g.Stats.Completed.Value == true
                                local genCol = isDone and Color3.fromRGB(0, 255, 120) or Color3.fromRGB(255, 220, 0)
                                table.insert(entries, {Name = "Generator", Obj = g, Color = genCol, Order = 2, CanTP = true}) 
                            end
                        end
                        if part:FindFirstChild("Items") then
                            for _, i in pairs(part.Items:GetChildren()) do
                                local isH = (i.Name == "HealthKit" or i.Name == "Bandage"); local isC = (i.Name == "ResearchCapsule")
                                if Toggles.TrackAllItems or (isH and Toggles.TrackHealth) or (isC and Toggles.TrackCapsules) then
                                    local col = isH and Color3.fromRGB(0, 255, 100) or isC and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(255, 255, 255)
                                    table.insert(entries, {Name = i.Name, Obj = i, Color = col, Order = 3, CanTP = true})
                                end
                            end
                        end
                    end
                end
                
                if Toggles.TrackMonsters then
                    for _, desc in pairs(room:GetDescendants()) do
                        if (desc.Name == "SproutTendril" or desc.Name:find("BlotHandZone")) and desc:IsA("BasePart") then
                             table.insert(entries, {Name = "[!] Hazard Zone", Obj = desc, Color = Color3.fromRGB(255, 80, 0), Order = 1, CanTP = false})
                        end
                    end
                end

                for _, d in pairs(entries) do
                    local b = Instance.new("TextButton", ScrollingFrame)
                    b.Size = UDim2.new(0.9, 0, 0, 25); b.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                    b.Text = d.Name; b.TextColor3 = d.Color; b.Font = Enum.Font.GothamSemibold; b.TextSize = 11; b.LayoutOrder = d.Order
                    b.TextXAlignment = Enum.TextXAlignment.Center
                    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
                    if d.CanTP then b.MouseButton1Click:Connect(function() TeleportTo(d.Obj) end) end
                end
            end
        end
        task.wait(3)
    end
end)

